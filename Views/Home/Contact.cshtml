@model gfps.Models.ContactInquiry
@{
    ViewData["Title"] = "Contact Us";
}

<!-- Hero Section -->
<section class="py-5 px-margin-mobile md:px-margin-desktop overflow-hidden bg-white border-bottom">
    <div class="container-xxl py-5">
        <h1 class="font-headline-xl text-primary text-center mb-2">Connect with Us</h1>
        <p class="font-body-lg text-secondary-emphasis text-center max-w-2xl mx-auto">We are here to assist you. Reach out to our admissions panel, administrative department, or schedule a campus tour.</p>
    </div>
</section>

<!-- Contact Info & Form -->
<section class="py-5 bg-light">
    <div class="container-xxl py-5">
        <div class="row g-5">
            <!-- Left Info Panel -->
            <div class="col-lg-5">
                <div class="d-flex flex-column gap-4">
                    <!-- Card 1 -->
                    <div class="p-4 bg-white border rounded shadow-sm d-flex gap-3">
                        <span class="material-symbols-outlined text-secondary fs-1">meeting_room</span>
                        <div>
                            <h4 class="mb-1 text-primary">Admissions Office</h4>
                            <p class="text-sm text-muted mb-1">Hours: Mon-Fri, 9am - 3pm</p>
                            <p class="text-sm mb-0">Phone: +1 (555) 123-4568</p>
                            <p class="text-sm mb-0">Email: <a href="mailto:admissions@greenfield.edu">admissions@greenfield.edu</a></p>
                        </div>
                    </div>
                    <!-- Card 2 -->
                    <div class="p-4 bg-white border rounded shadow-sm d-flex gap-3">
                        <span class="material-symbols-outlined text-secondary fs-1">admin_panel_settings</span>
                        <div>
                            <h4 class="mb-1 text-primary">Administration</h4>
                            <p class="text-sm text-muted mb-1">Hours: Mon-Fri, 8am - 4pm</p>
                            <p class="text-sm mb-0">Phone: +1 (555) 123-4567</p>
                            <p class="text-sm mb-0">Email: <a href="mailto:info@greenfield.edu">info@greenfield.edu</a></p>
                        </div>
                    </div>
                    <!-- Card 3 -->
                    <div class="p-4 bg-white border rounded shadow-sm d-flex gap-3">
                        <span class="material-symbols-outlined text-secondary fs-1">work</span>
                        <div>
                            <h4 class="mb-1 text-primary">Human Resources</h4>
                            <p class="text-sm text-muted mb-1">Hours: Mon-Thu, 9am - 4pm</p>
                            <p class="text-sm mb-0">Phone: +1 (555) 123-4569</p>
                            <p class="text-sm mb-0">Email: <a href="mailto:careers@greenfield.edu">careers@greenfield.edu</a></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Form Panel -->
            <div class="col-lg-7">
                <div class="p-5 bg-white border rounded shadow-sm">
                    <h3 class="mb-4 text-primary">Send a Message</h3>
                    
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["Error"]
                        </div>
                    }

                    <form action="/Home/SubmitContact" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="Name" class="form-label text-muted">Full Name</label>
                            <input type="text" class="form-control" id="Name" name="Name" required placeholder="e.g. John Doe" />
                        </div>

                        <div class="mb-3">
                            <label for="Email" class="form-label text-muted">Email Address</label>
                            <input type="email" class="form-control" id="Email" name="Email" required placeholder="john@example.com" />
                        </div>

                        <div class="mb-3">
                            <label for="Subject" class="form-label text-muted">Subject</label>
                            <input type="text" class="form-control" id="Subject" name="Subject" required placeholder="e.g. Inquiry regarding Kindergarten admission" />
                        </div>

                        <div class="mb-4">
                            <label for="Message" class="form-label text-muted">Message</label>
                            <textarea class="form-control" id="Message" name="Message" rows="5" required placeholder="Write your detailed inquiry here..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary btn-primary-admin py-3 px-4 w-100">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
