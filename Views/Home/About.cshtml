@{
    ViewData["Title"] = "About Us";
}

<!-- Hero Section -->
<section class="py-5 px-margin-mobile md:px-margin-desktop overflow-hidden">
    <div class="container-xxl py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <span class="inline-block py-2 px-4 rounded-pill bg-primary-subtle text-primary font-label-md mb-4 uppercase tracking-wider">Our History</span>
                <h1 class="font-headline-xl text-primary mb-4">A Legacy of Nurturing Excellence</h1>
                <p class="font-body-lg text-secondary-emphasis">
                    Founded in 1995, Green Field Public School has grown from a local academy to a national benchmark of educational quality. We empower students to innovate, lead, and serve.
                </p>
            </div>
            <div class="col-lg-5">
                <img src="/images/img_1.jpg" class="img-fluid rounded-4 shadow" alt="GFPS Campus History" />
            </div>
        </div>
    </div>
</section>

<!-- Vision & Mission -->
<section class="py-5 bg-white border-top border-bottom border-light-subtle">
    <div class="container-xxl py-5">
        <div class="text-center mb-5">
            <h2 class="font-headline-xl text-primary">Core Philosophy</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card-shadow-custom p-4 h-100">
                    <span class="material-symbols-outlined text-secondary fs-1 mb-3">visibility</span>
                    <h3>Our Vision</h3>
                    <p class="font-body-md text-secondary-emphasis">
                        To be a global leader in education, developing future leaders who excel academically, think critically, and act ethically to build a sustainable world.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card-shadow-custom p-4 h-100">
                    <span class="material-symbols-outlined text-secondary fs-1 mb-3">center_focus_strong</span>
                    <h3>Our Mission</h3>
                    <p class="font-body-md text-secondary-emphasis">
                        To provide a nurturing, state-of-the-art learning environment that integrates traditional values with modern technological advancements, fostering collaborative discovery and excellence.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- History Timeline -->
<section class="py-5 bg-light">
    <div class="container-xxl py-5">
        <div class="text-center mb-5">
            <h2 class="font-headline-xl text-primary">Our Journey</h2>
        </div>

        <div class="row row-cols-1 row-cols-md-4 g-4 mt-2">
            <!-- 1995 -->
            <div class="col text-center">
                <div class="p-4 bg-white border rounded shadow-sm">
                    <h3 class="text-secondary fw-bold">1995</h3>
                    <h5 class="mb-3">The Foundation</h5>
                    <p class="text-muted text-sm">Founded with just 100 students in a single academic wing.</p>
                </div>
            </div>
            <!-- 2005 -->
            <div class="col text-center">
                <div class="p-4 bg-white border rounded shadow-sm">
                    <h3 class="text-secondary fw-bold">2005</h3>
                    <h5 class="mb-3">Campus Expansion</h5>
                    <p class="text-muted text-sm">Inaugurated the olympic sports wing and library complexes.</p>
                </div>
            </div>
            <!-- 2012 -->
            <div class="col text-center">
                <div class="p-4 bg-white border rounded shadow-sm">
                    <h3 class="text-secondary fw-bold">2012</h3>
                    <h5 class="mb-3">Tech Integration</h5>
                    <p class="text-muted text-sm">Deployed interactive smart panels across all classrooms.</p>
                </div>
            </div>
            <!-- 2023 -->
            <div class="col text-center">
                <div class="p-4 bg-white border rounded shadow-sm">
                    <h3 class="text-secondary fw-bold">2023</h3>
                    <h5 class="mb-3">Global Accolades</h5>
                    <p class="text-muted text-sm">Awarded the prestigious National Green Campus excellence marker.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Principal Message -->
<section class="py-5 bg-white border-top border-light-subtle">
    <div class="container-xxl py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-4 text-center">
                <img src="/images/img_32.jpg" class="rounded-circle border border-5 border-light-subtle shadow img-fluid" style="width: 280px; height: 280px; object-fit: cover;" alt="Dr. Eleanor Vance Principal" />
            </div>
            <div class="col-lg-8">
                <span class="text-secondary font-label-md uppercase tracking-wider mb-2 d-block">Message from the Principal</span>
                <h2 class="font-headline-xl text-primary">Dr. Eleanor Vance</h2>
                <blockquote class="blockquote font-body-lg text-secondary-emphasis mt-3 italic">
                    "At Green Field, we believe that education is not the filling of a bucket, but the lighting of a fire. Our goal is to kindle curiosity and foster resilient thinkers ready to serve humanity."
                </blockquote>
            </div>
        </div>
    </div>
</section>
