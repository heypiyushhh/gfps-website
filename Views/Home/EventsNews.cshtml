@model IEnumerable<gfps.Models.News>
@{
    ViewData["Title"] = "Events & News";
    var events = ViewBag.Events as List<gfps.Models.Event> ?? new List<gfps.Models.Event>();
}

<!-- Hero Section -->
<section class="py-5 px-margin-mobile md:px-margin-desktop overflow-hidden bg-white border-bottom">
    <div class="container-xxl py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <span class="inline-block py-2 px-4 rounded-pill bg-secondary-subtle text-secondary font-label-md mb-4 uppercase tracking-wider">Stay Informed</span>
                <h1 class="font-headline-xl text-primary mb-4">Stay Updated with <span class="text-secondary">Green Field</span></h1>
                <p class="font-body-lg text-secondary-emphasis">
                    Read the latest press releases, school stories, achievements, and keep track of upcoming events on campus.
                </p>
            </div>
            <div class="col-lg-5">
                <img src="/images/img_15.jpg" class="img-fluid rounded-4 shadow" alt="Events News Hero" />
            </div>
        </div>
    </div>
</section>

<!-- News & Featured stories -->
<section class="py-5 bg-light border-bottom">
    <div class="container-xxl py-5">
        <h2 class="font-headline-xl text-primary mb-5">Latest Stories</h2>

        <div class="row g-4">
            @foreach (var news in Model)
            {
                <div class="col-md-6">
                    <div class="card-shadow-custom bg-white border overflow-hidden h-100">
                        <div class="position-relative" style="height: 250px;">
                            <img src="@news.ImagePath" class="w-100 h-100 object-cover" alt="@news.Title" />
                            @if (news.IsFeatured)
                            {
                                <span class="position-absolute top-0 start-0 bg-warning text-dark font-label-md px-3 py-1.5 m-3 rounded">Featured</span>
                            }
                        </div>
                        <div class="p-4">
                            <span class="text-muted text-sm d-block mb-2">Published: @news.PublishDate.ToString("MMMM dd, yyyy")</span>
                            <h3 class="font-headline-md text-primary mb-3">@news.Title</h3>
                            <p class="text-secondary-emphasis">@news.Summary</p>
                            <p class="text-muted text-sm">@news.Content</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Upcoming Events -->
<section class="py-5 bg-white border-bottom">
    <div class="container-xxl py-5">
        <h2 class="font-headline-xl text-primary mb-5">Upcoming Events</h2>

        <div class="row g-4">
            @if (events.Count == 0)
            {
                <div class="col-12 text-center text-muted py-5">
                    <h5>No events scheduled at this time.</h5>
                </div>
            }
            @foreach (var ev in events)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card-shadow-custom bg-light border p-4 h-100 d-flex flex-column gap-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-secondary-subtle text-secondary px-3 py-1.5">@ev.EventDate.ToString("yyyy-MM-dd")</span>
                            <span class="material-symbols-outlined text-secondary">calendar_month</span>
                        </div>
                        <h4 class="text-primary mb-0">@ev.Title</h4>
                        <p class="text-muted text-sm mb-0"><strong>Location:</strong> @ev.Location</p>
                        <p class="text-secondary-emphasis mb-0">@ev.Description</p>
                        
                        @if (!string.IsNullOrEmpty(ev.RegistrationLink))
                        {
                            <a href="@ev.RegistrationLink" class="btn btn-sm btn-primary mt-auto py-2.5">Register Now</a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Newsletter -->
<section class="py-5 bg-light">
    <div class="container-xxl py-5">
        <div class="card bg-primary text-white p-5 rounded-4 shadow-lg text-center max-w-2xl mx-auto">
            <span class="material-symbols-outlined fs-1 mb-3 text-warning">mail</span>
            <h3>Never Miss an Update</h3>
            <p class="opacity-90 max-w-xl mx-auto mb-4">Subscribe to our monthly newsletter to get curriculum info, admissions reminders, and sports digests directly in your inbox.</p>
            
            <form class="row g-2 max-w-lg mx-auto" onsubmit="alert('Thank you for subscribing!'); return false;">
                <div class="col-sm-8">
                    <input type="email" class="form-control py-3" placeholder="Enter your email address" required />
                </div>
                <div class="col-sm-4">
                    <button type="submit" class="btn btn-warning w-100 py-3 font-label-md">Subscribe</button>
                </div>
            </form>
        </div>
    </div>
</section>
