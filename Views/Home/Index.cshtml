@{
    ViewData["Title"] = "Empowering Future Leaders";
}

<!-- Hero Section -->
<section class="position-relative pt-5 pb-5 px-margin-mobile md:px-margin-desktop overflow-hidden">
    <!-- Glassmorphic Accent Backgrounds -->
    <div class="position-absolute top-0 end-0 rounded-circle blur-3xl opacity-25 translate-middle-y" style="width: 500px; height: 500px; background-color: #dbe1ff; z-index: -1;"></div>
    <div class="position-absolute bottom-0 start-0 rounded-circle blur-3xl opacity-25 translate-middle-x" style="width: 400px; height: 400px; background-color: #dae2fd; z-index: -1;"></div>

    <div class="container-xxl py-5 relative z-1">
        <div class="row align-items-center g-5">
            <!-- Left Content -->
            <div class="col-lg-6 animate-fade-up visible">
                <span class="inline-block py-2 px-4 rounded-pill bg-secondary-subtle text-secondary font-label-md mb-4 shadow-sm border border-secondary-subtle">
                    Admissions Open 2024-25
                </span>
                <h1 class="font-display-lg-mobile md:font-display-lg text-primary mb-4 leading-tight">
                    Empowering Future Leaders Through <span class="text-secondary position-relative">Excellence</span> in Education
                </h1>
                <p class="font-body-lg text-secondary-emphasis mb-5 max-w-xl">
                    A premium educational ecosystem designed to foster innovation, critical thinking, and holistic development in state-of-the-art facilities.
                </p>
                <div class="d-flex flex-column flex-sm-row gap-3">
                    <a href="/Admissions" class="btn btn-lg btn-primary px-4 py-3 rounded-3 shadow-lg">
                        Apply For Admission
                    </a>
                    <a href="/Home/Facilities" class="btn btn-lg btn-outline-secondary px-4 py-3 rounded-3 d-flex align-items-center justify-content-center gap-2">
                        <span class="material-symbols-outlined">view_in_ar</span>
                        Virtual Campus Tour
                    </a>
                </div>
            </div>

            <!-- Right 3D Mockup -->
            <div class="col-lg-6 position-relative mt-5 mt-lg-0 animate-fade-up visible" style="transition-delay: 0.2s;">
                <div class="position-relative rounded-4 overflow-hidden shadow-lg border border-light-subtle">
                    <img alt="Green Field Public School Campus" class="img-fluid w-100 object-cover" src="/images/img_31.jpg" />
                    
                    <!-- Floating Stat Cards -->
                    <div class="position-absolute top-0 start-0 glass-panel p-3 rounded-3 shadow-md d-flex align-items-center gap-3 translate-middle-x mt-5 ms-5 d-none d-sm-flex">
                        <div class="rounded-circle bg-secondary-subtle text-secondary d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <span class="material-symbols-outlined">groups</span>
                        </div>
                        <div>
                            <div class="font-headline-md text-primary mb-0">5000+</div>
                            <div class="font-label-md text-secondary-emphasis">Students</div>
                        </div>
                    </div>

                    <div class="position-absolute bottom-0 end-0 glass-panel p-3 rounded-3 shadow-md d-flex align-items-center gap-3 translate-middle-x mb-5 me-5 d-none d-sm-flex">
                        <div class="rounded-circle bg-warning-subtle text-warning d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <span class="material-symbols-outlined">psychology</span>
                        </div>
                        <div>
                            <div class="font-headline-md text-primary mb-0">250+</div>
                            <div class="font-label-md text-secondary-emphasis">Expert Faculty</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us Section -->
<section class="py-5 bg-white border-top border-bottom border-light-subtle relative">
    <div class="container-xxl py-5">
        <div class="text-center mb-5 animate-fade-up visible">
            <span class="text-secondary font-label-md tracking-wider uppercase mb-2 d-block">Our Differentiator</span>
            <h2 class="font-headline-xl text-primary">Why Choose Us</h2>
        </div>
        
        <div class="row g-4">
            <!-- Feature Card 1 -->
            <div class="col-md-4">
                <div class="card-shadow-custom p-4 h-100">
                    <div class="rounded-3 bg-light text-secondary d-flex align-items-center justify-content-center mb-4" style="width: 64px; height: 64px;">
                        <span class="material-symbols-outlined fs-2">developer_board</span>
                    </div>
                    <h3 class="font-headline-md text-primary mb-3">Smart Classrooms</h3>
                    <p class="font-body-md text-secondary-emphasis">Interactive flat panels and IoT-enabled environments for immersive digital learning.</p>
                </div>
            </div>
            
            <!-- Feature Card 2 -->
            <div class="col-md-4">
                <div class="card-shadow-custom p-4 h-100">
                    <div class="rounded-3 bg-light text-secondary d-flex align-items-center justify-content-center mb-4" style="width: 64px; height: 64px;">
                        <span class="material-symbols-outlined fs-2">sports_basketball</span>
                    </div>
                    <h3 class="font-headline-md text-primary mb-3">Sports Excellence</h3>
                    <p class="font-body-md text-secondary-emphasis">Olympic-standard facilities for holistic physical development and competitive training.</p>
                </div>
            </div>
            
            <!-- Feature Card 3 -->
            <div class="col-md-4">
                <div class="card-shadow-custom p-4 h-100">
                    <div class="rounded-3 bg-light text-secondary d-flex align-items-center justify-content-center mb-4" style="width: 64px; height: 64px;">
                        <span class="material-symbols-outlined fs-2">science</span>
                    </div>
                    <h3 class="font-headline-md text-primary mb-3">Innovation Labs</h3>
                    <p class="font-body-md text-secondary-emphasis">Dedicated STEM labs, robotics arenas, and makerspaces for practical exploration.</p>
                </div>
            </div>
        </div>
    </div>
</section>
