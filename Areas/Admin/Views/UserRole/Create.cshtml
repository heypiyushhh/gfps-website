@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Admin User";
    var roles = ViewBag.Roles as List<string> ?? new List<string>();
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0">New User Account</h5>
        <p class="text-muted text-sm">Create an account for school administration or content editing.</p>
    </div>

    <form action="/Admin/UserRole/Create" method="post">
        @Html.AntiForgeryToken()

        <div class="text-danger mb-3" asp-validation-summary="All">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        foreach (var error in modelState.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            }
        </div>

        <div class="mb-3">
            <label for="fullName" class="form-label">Full Name</label>
            <input type="text" class="form-control" id="fullName" name="fullName" required placeholder="e.g. Robert Miller" />
        </div>

        <div class="mb-3">
            <label for="email" class="form-label">Email Address</label>
            <input type="email" class="form-control" id="email" name="email" required placeholder="staff@gfps.edu" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input type="password" class="form-control" id="password" name="password" required placeholder="Min 6 chars, uppercase, digit, symbol" />
        </div>

        <div class="mb-4">
            <label for="role" class="form-label">Assign System Role</label>
            <select class="form-select" id="role" name="role" required>
                @foreach (var role in roles)
                {
                    <option value="@role">@role</option>
                }
            </select>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin">Create User</button>
            <a href="/Admin/UserRole" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
