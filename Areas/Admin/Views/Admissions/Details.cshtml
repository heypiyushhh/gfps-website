@model gfps.Models.AdmissionApplication
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Review Admission Application";
}

<div class="row">
    <div class="col-md-8">
        <div class="card-admin">
            <h5 class="border-bottom pb-3 mb-3">Application Details</h5>
            <dl class="row">
                <dt class="col-sm-4">Candidate Full Name</dt>
                <dd class="col-sm-8"><strong>@Model.CandidateName</strong></dd>

                <dt class="col-sm-4">Date of Birth</dt>
                <dd class="col-sm-8">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</dd>

                <dt class="col-sm-4">Gender</dt>
                <dd class="col-sm-8">@Model.Gender</dd>

                <dt class="col-sm-4">Grade Applied For</dt>
                <dd class="col-sm-8">@Model.GradeApplied</dd>

                <dt class="col-sm-4">Submission Date</dt>
                <dd class="col-sm-8">@Model.SubmittedAt.ToString("MMMM dd, yyyy HH:mm:ss")</dd>
            </dl>

            <h5 class="border-top pt-4 border-bottom pb-3 mb-3 mt-4">Parent / Guardian Information</h5>
            <dl class="row">
                <dt class="col-sm-4">Parent Name</dt>
                <dd class="col-sm-8">@Model.ParentName</dd>

                <dt class="col-sm-4">Email Address</dt>
                <dd class="col-sm-8">@Model.ParentEmail</dd>

                <dt class="col-sm-4">Phone Number</dt>
                <dd class="col-sm-8">@Model.ParentPhone</dd>

                <dt class="col-sm-4">Residential Address</dt>
                <dd class="col-sm-8">@Model.Address</dd>
            </dl>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Status Management Panel -->
        <div class="card-admin">
            <h5 class="border-bottom pb-3 mb-3">Application Status</h5>
            <div class="mb-4">
                <span class="fs-6 text-muted">Current State:</span>
                <span class="badge @(Model.Status == "Accepted" ? "bg-success" : Model.Status == "Rejected" ? "bg-danger" : "bg-warning") fs-6 px-3 py-2 ms-2">
                    @Model.Status
                </span>
            </div>

            <form action="/Admin/Admissions/UpdateStatus/@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label for="status" class="form-label text-muted">Update Status</label>
                    <select class="form-select" id="status" name="status" required>
                        <option value="Submitted" selected="@(Model.Status == "Submitted")">Submitted</option>
                        <option value="Reviewing" selected="@(Model.Status == "Reviewing")">Reviewing</option>
                        <option value="Accepted" selected="@(Model.Status == "Accepted")">Accepted</option>
                        <option value="Rejected" selected="@(Model.Status == "Rejected")">Rejected</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary-admin w-100 py-2">Update Application</button>
            </form>
        </div>

        <div class="mt-3 text-center">
            <a href="/Admin/Admissions" class="btn btn-outline-dark w-100">Back to Applications List</a>
        </div>
    </div>
</div>
