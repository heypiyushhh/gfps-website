@model gfps.Models.Event
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Schedule Event";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0 fw-bold">Schedule New Event</h5>
        <p class="text-muted text-sm">Add details to calendar, upload banners and manage registration links.</p>
    </div>

    <form action="/Admin/Events/Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="Title" class="form-label">Event Title</label>
            <input type="text" class="form-control" id="Title" name="Title" required placeholder="e.g. Science Summit 2026" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="EventDate" class="form-label">Event Date</label>
                <input type="date" class="form-control" id="EventDate" name="EventDate" required />
            </div>
            <div class="col-md-6 mb-3">
                <label for="EventTime" class="form-label">Event Time</label>
                <input type="text" class="form-control" id="EventTime" name="EventTime" required placeholder="e.g. 09:00 AM - 03:00 PM" />
            </div>
        </div>

        <div class="mb-3">
            <label for="Location" class="form-label">Location</label>
            <input type="text" class="form-control" id="Location" name="Location" required placeholder="e.g. Main Auditorium & Lab Wing" />
        </div>

        <div class="mb-3">
            <label for="RegistrationLink" class="form-label">Registration URL (Optional)</label>
            <input type="url" class="form-control" id="RegistrationLink" name="RegistrationLink" placeholder="e.g. https://forms.gle/..." />
        </div>

        <div class="mb-3">
            <label for="ShortDescription" class="form-label">Short Description</label>
            <textarea class="form-control" id="ShortDescription" name="ShortDescription" rows="3" required placeholder="Brief intro for calendar previews..."></textarea>
        </div>

        <div class="mb-3">
            <label for="FullDescription" class="form-label">Full Description</label>
            <textarea class="form-control" id="FullDescription" name="FullDescription" rows="8" placeholder="Detailed event description..."></textarea>
        </div>

        <div class="mb-3">
            <label for="imageFile" class="form-label">Event Banner Image</label>
            <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" />
        </div>

        <div class="mb-4">
            <label for="galleryFiles" class="form-label">Additional Event Gallery Images (Multiple)</label>
            <input class="form-control" type="file" id="galleryFiles" name="galleryFiles" accept="image/*" multiple />
            <small class="text-muted">You can select multiple files to upload into the event photo album.</small>
        </div>

        <div class="mb-4 form-check form-switch">
            <input class="form-check-input" type="checkbox" id="IsPublished" name="IsPublished" value="true" checked />
            <label class="form-check-label" for="IsPublished">Publish instantly (Visible on public events calendar)</label>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin px-4">Schedule Event</button>
            <a href="/Admin/Events" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
