@model gfps.Models.Event
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Event Details";
    List<string> galleryPaths = new List<string>();
    if (!string.IsNullOrEmpty(Model.GalleryImagesJson))
    {
        try
        {
            galleryPaths = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.GalleryImagesJson) ?? new List<string>();
        }
        catch { }
    }
}

<div class="card-admin max-w-lg mx-auto">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h5 class="mb-0 fw-bold">Scheduled Event Details</h5>
            <p class="text-muted text-sm mb-0">View event calendars, details and album gallery.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/Events/Edit/@Model.Id" class="btn btn-sm btn-outline-dark d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">edit</span> Edit
            </a>
            <a href="/Admin/Events" class="btn btn-sm btn-outline-secondary">Back to List</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ImagePath))
    {
        <div class="mb-4 text-center">
            <img src="@Model.ImagePath" class="img-fluid rounded border shadow-sm" style="max-height: 250px; width: 100%; object-fit: cover;" alt="Event Banner" />
        </div>
    }

    <div class="row g-3">
        <div class="col-md-8">
            <label class="fw-bold text-muted small uppercase">Event Title</label>
            <p class="text-dark fw-bold fs-5">@Model.Title</p>
        </div>
        <div class="col-md-4">
            <label class="fw-bold text-muted small uppercase">Location</label>
            <p class="text-dark"><span class="material-symbols-outlined text-danger align-middle fs-6">location_on</span> @Model.Location</p>
        </div>

        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Event Date</label>
            <p class="text-dark fw-bold">@Model.EventDate.ToString("dd MMMM, yyyy")</p>
        </div>
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Event Time</label>
            <p class="text-dark">@Model.EventTime</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.RegistrationLink))
        {
            <div class="col-12">
                <label class="fw-bold text-muted small uppercase d-block mb-1">Registration Link</label>
                <a href="@Model.RegistrationLink" target="_blank" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-6">open_in_new</span> Open Link
                </a>
            </div>
        }

        <div class="col-12">
            <label class="fw-bold text-muted small uppercase">Short Description</label>
            <p class="text-dark">@Model.ShortDescription</p>
        </div>

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase d-block mb-2">Full Description (HTML Rendered)</label>
            <div class="border rounded p-3 bg-light">
                @Html.Raw(Model.FullDescription)
            </div>
        </div>

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase d-block mb-2">Event Photos</label>
            @if (galleryPaths.Count == 0)
            {
                <p class="text-muted small italic">No photos uploaded for this event album yet.</p>
            }
            else
            {
                <div class="row g-2">
                    @foreach (var imgPath in galleryPaths)
                    {
                        <div class="col-md-3 col-sm-4">
                            <a href="@imgPath" target="_blank">
                                <img src="@imgPath" class="img-thumbnail rounded hover-shadow-sm" style="width: 100%; height: 75px; object-fit: cover; cursor: pointer;" />
                            </a>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-12 border-top pt-3">
            <div class="row g-2 text-muted small">
                <div class="col-md-3">
                    <strong>Status:</strong>
                    <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="col-md-3">
                    <strong>Visibility:</strong>
                    <span class="badge @(Model.IsPublished ? "bg-info-subtle text-info" : "bg-warning-subtle text-warning")">
                        @(Model.IsPublished ? "Published" : "Draft")
                    </span>
                </div>
                <div class="col-md-3">
                    <strong>Created:</strong> @Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
                <div class="col-md-3">
                    <strong>Last Updated:</strong> @Model.UpdatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
            </div>
        </div>
    </div>
</div>
