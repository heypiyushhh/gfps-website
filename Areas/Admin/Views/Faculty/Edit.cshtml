@model gfps.Models.FacultyMember
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Faculty Member";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0">Edit Faculty Profile</h5>
        <p class="text-muted text-sm">Update details for @Model.Name.</p>
    </div>

    <form action="/Admin/Faculty/Edit/@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="ImagePath" value="@Model.ImagePath" />

        <div class="mb-3">
            <label for="Name" class="form-label">Full Name</label>
            <input type="text" class="form-control" id="Name" name="Name" value="@Model.Name" required />
        </div>

        <div class="mb-3">
            <label for="Designation" class="form-label">Designation</label>
            <input type="text" class="form-control" id="Designation" name="Designation" value="@Model.Designation" required />
        </div>

        <div class="mb-3">
            <label for="Department" class="form-label">Department</label>
            <select class="form-select" id="Department" name="Department" required>
                <option value="Science" selected="@(Model.Department == "Science")">Science</option>
                <option value="Mathematics" selected="@(Model.Department == "Mathematics")">Mathematics</option>
                <option value="Humanities" selected="@(Model.Department == "Humanities")">Humanities</option>
                <option value="Arts" selected="@(Model.Department == "Arts")">Arts</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="Bio" class="form-label">Biography</label>
            <textarea class="form-control" id="Bio" name="Bio" rows="4">@Model.Bio</textarea>
        </div>

        <div class="mb-3">
            <label for="DisplayOrder" class="form-label">Display Order</label>
            <input type="number" class="form-control" id="DisplayOrder" name="DisplayOrder" value="@Model.DisplayOrder" />
        </div>

        <div class="mb-4">
            <label class="form-label">Current Photo</label>
            <div class="mb-2">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="rounded border" style="width: 80px; height: 80px; object-fit: cover;" />
                }
                else
                {
                    <span class="text-muted text-sm">No photo uploaded</span>
                }
            </div>
            <label for="imageFile" class="form-label">Upload New Photo</label>
            <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" />
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin">Save Changes</button>
            <a href="/Admin/Faculty" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
