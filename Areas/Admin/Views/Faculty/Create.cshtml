@model gfps.Models.FacultyMember
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Faculty Member";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0">New Faculty Profile</h5>
        <p class="text-muted text-sm">Add a new educator to the school directory.</p>
    </div>

    <form action="/Admin/Faculty/Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="Name" class="form-label">Full Name</label>
            <input type="text" class="form-control" id="Name" name="Name" required placeholder="e.g. Dr. Jane Smith" />
        </div>

        <div class="mb-3">
            <label for="Designation" class="form-label">Designation</label>
            <input type="text" class="form-control" id="Designation" name="Designation" required placeholder="e.g. Senior Physics Lecturer" />
        </div>

        <div class="mb-3">
            <label for="Department" class="form-label">Department</label>
            <select class="form-select" id="Department" name="Department" required>
                <option value="Science">Science</option>
                <option value="Mathematics">Mathematics</option>
                <option value="Humanities">Humanities</option>
                <option value="Arts">Arts</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="Bio" class="form-label">Biography</label>
            <textarea class="form-control" id="Bio" name="Bio" rows="4" placeholder="Brief history and qualifications..."></textarea>
        </div>

        <div class="mb-3">
            <label for="DisplayOrder" class="form-label">Display Order</label>
            <input type="number" class="form-control" id="DisplayOrder" name="DisplayOrder" value="0" />
            <small class="text-muted">Lower numbers appear first in the public listing.</small>
        </div>

        <div class="mb-4">
            <label for="imageFile" class="form-label">Profile Image</label>
            <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" />
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin">Save Faculty</button>
            <a href="/Admin/Faculty" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
