@model IEnumerable<gfps.Models.FacultyMember>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Faculty Directory Management";
}

<div class="card-admin">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">Faculty Directory</h5>
        <a href="/Admin/Faculty/Create" class="btn btn-primary btn-primary-admin d-flex align-items-center gap-1">
            <span class="material-symbols-outlined">add</span>
            Add Faculty Member
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 80px;">Photo</th>
                    <th>Name</th>
                    <th>Designation</th>
                    <th>Department</th>
                    <th>Order</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No faculty members found.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover;" alt="@item.Name" />
                            }
                            else
                            {
                                <div class="bg-secondary-subtle rounded-circle d-flex align-items-center justify-center text-secondary font-weight-bold" style="width: 48px; height: 48px;">
                                    @item.Name.Substring(0, 1)
                                </div>
                            }
                        </td>
                        <td><strong>@item.Name</strong></td>
                        <td>@item.Designation</td>
                        <td>
                            <span class="badge bg-secondary-subtle text-secondary">@item.Department</span>
                        </td>
                        <td>@item.DisplayOrder</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/Admin/Faculty/Edit/@item.Id" class="btn btn-sm btn-outline-dark">Edit</a>
                                <form action="/Admin/Faculty/Delete/@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this faculty member?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
