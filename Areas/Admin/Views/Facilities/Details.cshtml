@model gfps.Models.Facility
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Facility Details";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h5 class="mb-0 fw-bold">Facility details</h5>
            <p class="text-muted text-sm mb-0">View infrastructure and assets information.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/Facilities/Edit/@Model.Id" class="btn btn-sm btn-outline-dark d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">edit</span> Edit
            </a>
            <a href="/Admin/Facilities" class="btn btn-sm btn-outline-secondary">Back to List</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ImagePath))
    {
        <div class="mb-4 text-center">
            <img src="@Model.ImagePath" class="img-fluid rounded border shadow-sm" style="max-height: 250px; width: 100%; object-fit: cover;" alt="Facility Photo" />
        </div>
    }

    <div class="row g-3">
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Facility Name</label>
            <p class="text-dark fw-bold fs-5">@Model.Name</p>
        </div>
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Material Icon</label>
            <p class="d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-primary fs-3">@Model.Icon</span>
                <code>@Model.Icon</code>
            </p>
        </div>

        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Display Order</label>
            <p class="text-dark">@Model.DisplayOrder</p>
        </div>
        <div class="col-md-6">
            <strong>Status:</strong><br/>
            <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                @(Model.IsActive ? "Active" : "Inactive")
            </span>
        </div>

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase">Short Description</label>
            <p class="text-dark">@Model.Description</p>
        </div>

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase d-block mb-1">Full Specifications & Details</label>
            <div class="border rounded p-3 bg-light">
                <p class="mb-0 text-secondary" style="white-space: pre-line;">@Model.Details</p>
            </div>
        </div>

        <div class="col-12 border-top pt-3">
            <div class="row g-2 text-muted small">
                <div class="col-md-6">
                    <strong>Created:</strong> @Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
                <div class="col-md-6">
                    <strong>Last Updated:</strong> @Model.UpdatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
            </div>
        </div>
    </div>
</div>
