@model gfps.Models.News
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Write News Article";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0 fw-bold">Write News Article</h5>
        <p class="text-muted text-sm">Create school bulletins, announcements or press releases.</p>
    </div>

    <form action="/Admin/News/Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="Title" class="form-label">News Title</label>
            <input type="text" class="form-control" id="Title" name="Title" required placeholder="e.g. Science Fair Laurels 2026" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="Slug" class="form-label">URL Slug (Optional)</label>
                <input type="text" class="form-control" id="Slug" name="Slug" placeholder="e.g. science-fair-laurels-2026" />
                <small class="text-muted">Auto-generated from title if left blank.</small>
            </div>
            <div class="col-md-6 mb-3">
                <label for="Author" class="form-label">Author / Department</label>
                <input type="text" class="form-control" id="Author" name="Author" required value="Principal's Office" placeholder="e.g. Science Club Dean" />
            </div>
        </div>

        <div class="mb-3">
            <label for="PublishDate" class="form-label">Publish Date</label>
            <input type="date" class="form-control" id="PublishDate" name="PublishDate" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
        </div>

        <div class="mb-3">
            <label for="Summary" class="form-label">Short Summary (Short Description)</label>
            <textarea class="form-control" id="Summary" name="Summary" rows="3" required placeholder="Brief intro to display on lists..."></textarea>
        </div>

        <div class="mb-3">
            <label for="Content" class="form-label">Full Content (Rich Text Editor)</label>
            <textarea class="form-control rich-editor" id="Content" name="Content" rows="8"></textarea>
        </div>

        <div class="mb-4">
            <label for="imageFile" class="form-label">Featured Article Image</label>
            <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" />
        </div>

        <div class="row mb-4">
            <div class="col-md-6 form-check form-switch ps-5">
                <input class="form-check-input" type="checkbox" id="IsFeatured" name="IsFeatured" value="true" />
                <label class="form-check-label" for="IsFeatured">Mark as Featured Article</label>
            </div>
            <div class="col-md-6 form-check form-switch ps-5">
                <input class="form-check-input" type="checkbox" id="IsPublished" name="IsPublished" value="true" checked />
                <label class="form-check-label" for="IsPublished">Publish instantly (Visible to public)</label>
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin px-4">Publish Article</button>
            <a href="/Admin/News" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <!-- TinyMCE Rich Text Editor -->
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '.rich-editor',
            plugins: 'lists link code table wordcount',
            toolbar: 'undo redo | formatselect | bold italic | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link table code | removeformat',
            menubar: false,
            height: 300,
            setup: function (editor) {
                editor.on('change', function () {
                    editor.save();
                });
            }
        });
    </script>
}
