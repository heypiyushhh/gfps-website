@model gfps.Models.News
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit News Article";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0 fw-bold">Edit News Article</h5>
        <p class="text-muted text-sm">Modify title, content, featured flags, or swap images.</p>
    </div>

    <form action="/Admin/News/Edit/@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="mb-3">
            <label for="Title" class="form-label">News Title</label>
            <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="Slug" class="form-label">URL Slug</label>
                <input type="text" class="form-control" id="Slug" name="Slug" value="@Model.Slug" required />
                <small class="text-muted">Slug determines the article URL structure.</small>
            </div>
            <div class="col-md-6 mb-3">
                <label for="Author" class="form-label">Author / Department</label>
                <input type="text" class="form-control" id="Author" name="Author" value="@Model.Author" required />
            </div>
        </div>

        <div class="mb-3">
            <label for="PublishDate" class="form-label">Publish Date</label>
            <input type="date" class="form-control" id="PublishDate" name="PublishDate" value="@Model.PublishDate.ToString("yyyy-MM-dd")" required />
        </div>

        <div class="mb-3">
            <label for="Summary" class="form-label">Short Summary</label>
            <textarea class="form-control" id="Summary" name="Summary" rows="3" required>@Model.Summary</textarea>
        </div>

        <div class="mb-3">
            <label for="Content" class="form-label">Full Content (Rich Text Editor)</label>
            <textarea class="form-control rich-editor" id="Content" name="Content" rows="8">@Model.Content</textarea>
        </div>

        <div class="mb-4">
            <label class="form-label d-block fw-bold">Featured Article Image</label>
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="mb-2">
                    <img src="@Model.ImagePath" class="img-thumbnail rounded" style="max-height: 120px;" alt="News Image" />
                </div>
            }
            <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" />
        </div>

        <div class="row mb-4">
            <div class="col-md-6 form-check form-switch ps-5">
                <input class="form-check-input" type="checkbox" id="IsFeatured" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") />
                <label class="form-check-label" for="IsFeatured">Mark as Featured Article</label>
            </div>
            <div class="col-md-6 form-check form-switch ps-5">
                <input class="form-check-input" type="checkbox" id="IsPublished" name="IsPublished" value="true" @(Model.IsPublished ? "checked" : "") />
                <label class="form-check-label" for="IsPublished">Publish instantly (Visible to public)</label>
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin px-4">Save Changes</button>
            <a href="/Admin/News" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <!-- TinyMCE Rich Text Editor -->
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '.rich-editor',
            plugins: 'lists link code table wordcount',
            toolbar: 'undo redo | formatselect | bold italic | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link table code | removeformat',
            menubar: false,
            height: 300,
            setup: function (editor) {
                editor.on('change', function () {
                    editor.save();
                });
            }
        });
    </script>
}
