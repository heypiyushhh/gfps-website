@model IEnumerable<gfps.Models.News>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "News Feed Management";
    string searchTerm = ViewBag.SearchTerm as string ?? "";
    int currentPage = ViewBag.CurrentPage is int ? (int)ViewBag.CurrentPage : 1;
    int totalPages = ViewBag.TotalPages is int ? (int)ViewBag.TotalPages : 1;
    int totalItems = ViewBag.TotalItems is int ? (int)ViewBag.TotalItems : 0;
}

<div class="card-admin">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h5 class="mb-0 fw-bold">School News Feed</h5>
            <p class="text-muted text-sm mb-0">Publish announcements, press releases, achievements and bulletins.</p>
        </div>
        <a href="/Admin/News/Create" class="btn btn-primary btn-primary-admin d-flex align-items-center gap-1 align-self-start">
            <span class="material-symbols-outlined">add</span>
            Write News Article
        </a>
    </div>

    <!-- Search Form -->
    <form method="get" action="/Admin/News" class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="searchTerm" class="form-control" placeholder="Search by title, author or summary..." value="@searchTerm" />
                <button class="btn btn-primary btn-primary-admin" type="submit">Search</button>
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <a href="/Admin/News" class="btn btn-outline-secondary d-flex align-items-center">
                        <span class="material-symbols-outlined fs-6">close</span>
                    </a>
                }
            </div>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 80px;">Thumbnail</th>
                    <th>News Title</th>
                    <th>Author</th>
                    <th>Publish Date</th>
                    <th style="width: 100px;">Featured</th>
                    <th style="width: 100px;">Visibility</th>
                    <th style="width: 100px;">Status</th>
                    <th style="width: 160px; text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No news articles found.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" class="rounded border" style="width: 50px; height: 35px; object-fit: cover;" alt="@item.Title" />
                            }
                            else
                            {
                                <div class="bg-secondary-subtle rounded border d-flex align-items-center justify-content-center text-secondary small" style="width: 50px; height: 35px;">
                                    <span class="material-symbols-outlined fs-6">newspaper</span>
                                </div>
                            }
                        </td>
                        <td>
                            <strong>@item.Title</strong><br/>
                            <small class="text-muted">Slug: @item.Slug</small>
                        </td>
                        <td>@item.Author</td>
                        <td>@item.PublishDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <form action="/Admin/News/ToggleFeatured/@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="border-0 bg-transparent p-0">
                                    <span class="badge @(item.IsFeatured ? "bg-warning text-dark" : "bg-secondary-subtle text-secondary")" style="cursor: pointer;">
                                        @(item.IsFeatured ? "Featured" : "Standard")
                                    </span>
                                </button>
                            </form>
                        </td>
                        <td>
                            <span class="badge @(item.IsPublished ? "bg-info-subtle text-info" : "bg-warning-subtle text-warning")">
                                @(item.IsPublished ? "Published" : "Draft")
                            </span>
                        </td>
                        <td>
                            <form action="/Admin/News/ToggleStatus/@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="border-0 bg-transparent p-0">
                                    <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")" style="cursor: pointer;">
                                        @(item.IsActive ? "Active" : "Inactive")
                                    </span>
                                </button>
                            </form>
                        </td>
                        <td align="right">
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="/Admin/News/Details/@item.Id" class="btn btn-sm btn-outline-info" title="View details">
                                    <span class="material-symbols-outlined fs-6">visibility</span>
                                </a>
                                <a href="/Admin/News/Edit/@item.Id" class="btn btn-sm btn-outline-dark" title="Edit">
                                    <span class="material-symbols-outlined fs-6">edit</span>
                                </a>
                                <form action="/Admin/News/Delete/@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this news article?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <span class="material-symbols-outlined fs-6">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <nav class="d-flex justify-content-between align-items-center mt-4">
            <p class="text-muted text-sm mb-0">Showing Page @currentPage of @totalPages (@totalItems items)</p>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="/Admin/News?searchTerm=@searchTerm&page=@(currentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <a class="page-link" href="/Admin/News?searchTerm=@searchTerm&page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="/Admin/News?searchTerm=@searchTerm&page=@(currentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
