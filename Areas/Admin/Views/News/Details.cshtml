@model gfps.Models.News
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "News Article Details";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h5 class="mb-0 fw-bold">News Article Details</h5>
            <p class="text-muted text-sm mb-0">View article copy, publishing parameters and thumbnails.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/News/Edit/@Model.Id" class="btn btn-sm btn-outline-dark d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">edit</span> Edit
            </a>
            <a href="/Admin/News" class="btn btn-sm btn-outline-secondary">Back to List</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ImagePath))
    {
        <div class="mb-4 text-center">
            <img src="@Model.ImagePath" class="img-fluid rounded border shadow-sm" style="max-height: 250px; width: 100%; object-fit: cover;" alt="Featured Image" />
        </div>
    }

    <div class="row g-3">
        <div class="col-md-8">
            <label class="fw-bold text-muted small uppercase">Title</label>
            <p class="text-dark fw-bold fs-5">@Model.Title</p>
        </div>
        <div class="col-md-4">
            <label class="fw-bold text-muted small uppercase">Author</label>
            <p class="text-dark"><span class="material-symbols-outlined align-middle fs-6">person</span> @Model.Author</p>
        </div>

        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Publish Date</label>
            <p class="text-dark fw-bold">@Model.PublishDate.ToString("dd MMMM, yyyy")</p>
        </div>
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">URL Slug</label>
            <p class="text-dark"><code>@Model.Slug</code></p>
        </div>

        <div class="col-12">
            <label class="fw-bold text-muted small uppercase">Short Summary</label>
            <p class="text-dark">@Model.Summary</p>
        </div>

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase d-block mb-2">Full Content (HTML Rendered)</label>
            <div class="border rounded p-3 bg-light">
                @Html.Raw(Model.Content)
            </div>
        </div>

        <div class="col-12 border-top pt-3">
            <div class="row g-2 text-muted small">
                <div class="col-md-3">
                    <strong>Status:</strong>
                    <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="col-md-3">
                    <strong>Featured:</strong>
                    <span class="badge @(Model.IsFeatured ? "bg-warning text-dark" : "bg-secondary-subtle text-secondary")">
                        @(Model.IsFeatured ? "Featured" : "Standard")
                    </span>
                </div>
                <div class="col-md-3">
                    <strong>Visibility:</strong>
                    <span class="badge @(Model.IsPublished ? "bg-info-subtle text-info" : "bg-warning-subtle text-warning")">
                        @(Model.IsPublished ? "Published" : "Draft")
                    </span>
                </div>
                <div class="col-md-3">
                    <strong>Created:</strong> @Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
            </div>
        </div>
    </div>
</div>
