@model gfps.Models.Achievement
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Achievement Details";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h5 class="mb-0 fw-bold">Achievement Details</h5>
            <p class="text-muted text-sm mb-0">View student/teacher accolades and verification files.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/Achievements/Edit/@Model.Id" class="btn btn-sm btn-outline-dark d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">edit</span> Edit
            </a>
            <a href="/Admin/Achievements" class="btn btn-sm btn-outline-secondary">Back to List</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ImagePath))
    {
        <div class="mb-4 text-center">
            <img src="@Model.ImagePath" class="img-fluid rounded border shadow-sm" style="max-height: 250px; width: 100%; object-fit: cover;" alt="Achievement Photo" />
        </div>
    }

    <div class="row g-3">
        <div class="col-md-8">
            <label class="fw-bold text-muted small uppercase">Title / Accolade Name</label>
            <p class="text-dark fw-bold fs-5">@Model.Title</p>
        </div>
        <div class="col-md-4">
            <label class="fw-bold text-muted small uppercase">Recipient</label>
            <p class="text-dark fw-bold">@Model.RecipientName</p>
        </div>

        <div class="col-md-4">
            <label class="fw-bold text-muted small uppercase">Academic Year</label>
            <p class="text-dark">@Model.Year</p>
        </div>
        <div class="col-md-4">
            <label class="fw-bold text-muted small uppercase">Date Awarded</label>
            <p class="text-dark">@Model.AchievementDate.ToString("dd MMMM, yyyy")</p>
        </div>
        <div class="col-md-4">
            <label class="fw-bold text-muted small uppercase">Material Icon</label>
            <p class="d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-warning">@Model.Icon</span>
                <code>@Model.Icon</code>
            </p>
        </div>

        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Recipient Type</label>
            <p><span class="badge bg-secondary-subtle text-secondary">@Model.AchievementType</span></p>
        </div>
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Category</label>
            <p><span class="badge bg-info-subtle text-info">@Model.Category</span></p>
        </div>

        @if (!string.IsNullOrEmpty(Model.CertificatePath))
        {
            <div class="col-12 border-top pt-3">
                <label class="fw-bold text-muted small uppercase d-block mb-1">Verification Document</label>
                <a href="@Model.CertificatePath" target="_blank" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-6">open_in_new</span> Open Certificate
                </a>
            </div>
        }

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase">Detailed Description</label>
            <div class="border rounded p-3 bg-light text-secondary" style="white-space: pre-line;">
                @Model.Description
            </div>
        </div>

        <div class="col-12 border-top pt-3">
            <div class="row g-2 text-muted small">
                <div class="col-md-4">
                    <strong>Status:</strong>
                    <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="col-md-4">
                    <strong>Created:</strong> @Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
                <div class="col-md-4">
                    <strong>Last Updated:</strong> @Model.UpdatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
            </div>
        </div>
    </div>
</div>
