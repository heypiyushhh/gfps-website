@model gfps.Models.Achievement
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Achievement Record";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0 fw-bold">Edit Achievement Details</h5>
        <p class="text-muted text-sm">Modify recipient name, category, dates, description, or swap files.</p>
    </div>

    <form action="/Admin/Achievements/Edit/@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="mb-3">
            <label for="Title" class="form-label">Achievement Title</label>
            <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required />
        </div>

        <div class="mb-3">
            <label for="RecipientName" class="form-label">Recipient Name</label>
            <input type="text" class="form-control" id="RecipientName" name="RecipientName" value="@Model.RecipientName" required />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="Year" class="form-label">Academic Year</label>
                <input type="text" class="form-control" id="Year" name="Year" value="@Model.Year" required />
            </div>
            <div class="col-md-6 mb-3">
                <label for="AchievementDate" class="form-label">Achievement Date</label>
                <input type="date" class="form-control" id="AchievementDate" name="AchievementDate" value="@Model.AchievementDate.ToString("yyyy-MM-dd")" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="AchievementType" class="form-label">Recipient Type</label>
                <select class="form-select" id="AchievementType" name="AchievementType" required>
                    <option value="Student" selected="@(Model.AchievementType == "Student")">Student</option>
                    <option value="Teacher" selected="@(Model.AchievementType == "Teacher")">Teacher</option>
                    <option value="School" selected="@(Model.AchievementType == "School")">School / Institution</option>
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label for="Category" class="form-label">Category</label>
                <select class="form-select" id="Category" name="Category" required>
                    <option value="Accolades" selected="@(Model.Category == "Accolades")">Accolades & Awards</option>
                    <option value="Athletics" selected="@(Model.Category == "Athletics")">Athletics & Sports</option>
                    <option value="Student" selected="@(Model.Category == "Student")">Student Performance</option>
                    <option value="Cultural" selected="@(Model.Category == "Cultural")">Arts & Culture</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="Icon" class="form-label">Material Icon Name</label>
                <input type="text" class="form-control" id="Icon" name="Icon" value="@Model.Icon" />
            </div>
            <div class="col-md-6 mb-3">
                &nbsp;
            </div>
        </div>

        <div class="mb-3">
            <label for="Description" class="form-label">Detailed Description</label>
            <textarea class="form-control" id="Description" name="Description" rows="4" required>@Model.Description</textarea>
        </div>

        <div class="mb-4">
            <label class="form-label d-block fw-bold">Achievement Photo</label>
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="mb-2">
                    <img src="@Model.ImagePath" class="img-thumbnail rounded" style="max-height: 120px;" alt="Photo" />
                </div>
            }
            <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" />
        </div>

        <div class="mb-4">
            <label class="form-label d-block fw-bold">Certificate File</label>
            @if (!string.IsNullOrEmpty(Model.CertificatePath))
            {
                <div class="mb-2">
                    <a href="@Model.CertificatePath" target="_blank" class="btn btn-sm btn-outline-info d-inline-flex align-items-center gap-1">
                        <span class="material-symbols-outlined fs-6">description</span> View Stored Certificate
                    </a>
                </div>
            }
            <input class="form-control" type="file" id="certificateFile" name="certificateFile" accept="application/pdf,image/*" />
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin px-4">Save Changes</button>
            <a href="/Admin/Achievements" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
