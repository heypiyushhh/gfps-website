@model gfps.Models.Achievement
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Achievement Record";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0 fw-bold">New Achievement Record</h5>
        <p class="text-muted text-sm">Add student honors, team accomplishments, or school ratings.</p>
    </div>

    <form action="/Admin/Achievements/Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="Title" class="form-label">Achievement Title</label>
            <input type="text" class="form-control" id="Title" name="Title" required placeholder="e.g. Under-19 Football Gold Medal" />
        </div>

        <div class="mb-3">
            <label for="RecipientName" class="form-label">Recipient Name (Student, Teacher or Team Name)</label>
            <input type="text" class="form-control" id="RecipientName" name="RecipientName" required placeholder="e.g. Aisha Sharma / Varsity Soccer Team" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="Year" class="form-label">Academic Year</label>
                <input type="text" class="form-control" id="Year" name="Year" required placeholder="e.g. 2026" />
            </div>
            <div class="col-md-6 mb-3">
                <label for="AchievementDate" class="form-label">Achievement Date</label>
                <input type="date" class="form-control" id="AchievementDate" name="AchievementDate" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="AchievementType" class="form-label">Recipient Type</label>
                <select class="form-select" id="AchievementType" name="AchievementType" required>
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                    <option value="School">School / Institution</option>
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label for="Category" class="form-label">Category</label>
                <select class="form-select" id="Category" name="Category" required>
                    <option value="Accolades">Accolades & Awards</option>
                    <option value="Athletics">Athletics & Sports</option>
                    <option value="Student">Student Performance</option>
                    <option value="Cultural">Arts & Culture</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="Icon" class="form-label">Material Icon Name</label>
                <input type="text" class="form-control" id="Icon" name="Icon" value="emoji_events" placeholder="e.g. workspace_premium, trophy" />
            </div>
            <div class="col-md-6 mb-3">
                &nbsp;
            </div>
        </div>

        <div class="mb-3">
            <label for="Description" class="form-label">Detailed Description</label>
            <textarea class="form-control" id="Description" name="Description" rows="4" required placeholder="Summary of the accolade, context, and background..."></textarea>
        </div>

        <div class="mb-3">
            <label for="imageFile" class="form-label">Achievement Photo</label>
            <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" />
        </div>

        <div class="mb-4">
            <label for="certificateFile" class="form-label">Certificate PDF Upload (Optional)</label>
            <input class="form-control" type="file" id="certificateFile" name="certificateFile" accept="application/pdf,image/*" />
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin px-4">Save Achievement</button>
            <a href="/Admin/Achievements" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
