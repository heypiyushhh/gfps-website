@model gfps.Models.AcademicProgram
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Academic Program Details";
    var curriculumList = ViewBag.CurriculumList as List<string> ?? new List<string>();
}

<div class="card-admin max-w-lg mx-auto">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h5 class="mb-0 fw-bold">Stream Details</h5>
            <p class="text-muted text-sm mb-0">View curriculum configurations and details.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/AcademicPrograms/Edit/@Model.Id" class="btn btn-sm btn-outline-dark d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">edit</span> Edit
            </a>
            <a href="/Admin/AcademicPrograms" class="btn btn-sm btn-outline-secondary">Back to List</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.FeaturedImage))
    {
        <div class="mb-4 text-center">
            <img src="@Model.FeaturedImage" class="img-fluid rounded border shadow-sm" style="max-height: 250px; width: 100%; object-fit: cover;" alt="Featured Image" />
        </div>
    }

    <div class="row g-3">
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Title</label>
            <p class="text-dark fw-bold fs-5">@Model.Title</p>
        </div>
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Department</label>
            <p><span class="badge bg-secondary-subtle text-secondary">@Model.Department</span></p>
        </div>

        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Class / Grade Range</label>
            <p class="text-dark">@Model.ClassOrGrade</p>
        </div>
        <div class="col-md-6">
            <label class="fw-bold text-muted small uppercase">Icon Name</label>
            <p class="d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-primary">@Model.Icon</span>
                <code>@Model.Icon</code>
            </p>
        </div>

        <div class="col-12">
            <label class="fw-bold text-muted small uppercase">Core Subjects</label>
            <p class="text-dark">@Model.Subject</p>
        </div>

        <div class="col-12">
            <label class="fw-bold text-muted small uppercase">Short Description</label>
            <p class="text-dark">@Model.Description</p>
        </div>

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase d-block mb-2">Full Description (HTML Rendered)</label>
            <div class="border rounded p-3 bg-light">
                @Html.Raw(Model.FullDescription)
            </div>
        </div>

        <div class="col-12 border-top pt-3">
            <label class="fw-bold text-muted small uppercase d-block mb-2">Curriculum Topics</label>
            @if (curriculumList.Count == 0)
            {
                <p class="text-muted italic">No curriculum topics registered.</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var topic in curriculumList)
                    {
                        <li class="list-group-item d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined text-success fs-5">check_circle</span>
                            <span>@topic</span>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="col-12 border-top pt-3">
            <div class="row g-2 text-muted small">
                <div class="col-md-4">
                    <strong>Status:</strong>
                    <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="col-md-4">
                    <strong>Created:</strong> @Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
                <div class="col-md-4">
                    <strong>Last Updated:</strong> @Model.UpdatedDate.ToString("yyyy-MM-dd HH:mm")
                </div>
            </div>
        </div>
    </div>
</div>
