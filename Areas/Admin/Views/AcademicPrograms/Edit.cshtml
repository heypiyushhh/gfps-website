@model gfps.Models.AcademicProgram
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Academic Stream";
    string curriculumText = ViewBag.CurriculumText as string ?? "";
}

<div class="card-admin max-w-lg mx-auto">
    <div class="mb-4">
        <h5 class="mb-0 fw-bold">Edit Academic Stream</h5>
        <p class="text-muted text-sm">Update stream settings, curriculum details, or images.</p>
    </div>

    <form action="/Admin/AcademicPrograms/Edit/@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="mb-3">
            <label for="Title" class="form-label">Stream Title</label>
            <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required />
        </div>

        <div class="mb-3">
            <label for="Department" class="form-label">Department</label>
            <select class="form-select" id="Department" name="Department" required>
                <option value="Science" selected="@(Model.Department == "Science")">Science</option>
                <option value="Commerce" selected="@(Model.Department == "Commerce")">Commerce</option>
                <option value="Humanities" selected="@(Model.Department == "Humanities")">Humanities</option>
                <option value="Vocational" selected="@(Model.Department == "Vocational")">Vocational</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="ClassOrGrade" class="form-label">Class / Grade Range</label>
            <input type="text" class="form-control" id="ClassOrGrade" name="ClassOrGrade" value="@Model.ClassOrGrade" required />
        </div>

        <div class="mb-3">
            <label for="Subject" class="form-label">Core Subjects List</label>
            <input type="text" class="form-control" id="Subject" name="Subject" value="@Model.Subject" required />
            <small class="text-muted">Comma-separated list of subjects.</small>
        </div>

        <div class="mb-3">
            <label for="Description" class="form-label">Short Description</label>
            <textarea class="form-control" id="Description" name="Description" rows="3" required>@Model.Description</textarea>
        </div>

        <div class="mb-3">
            <label for="FullDescription" class="form-label">Full Description</label>
            <textarea class="form-control" id="FullDescription" name="FullDescription" rows="8">@Model.FullDescription</textarea>
        </div>

        <div class="mb-3">
            <label for="curriculumText" class="form-label">Curriculum Topics / Syllabus</label>
            <textarea class="form-control" id="curriculumText" name="curriculumText" rows="6">@curriculumText</textarea>
            <small class="text-muted">Enter one curriculum topic per line. These will be parsed into bullet points.</small>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="DisplayOrder" class="form-label">Display Order</label>
                <input type="number" class="form-control" id="DisplayOrder" name="DisplayOrder" value="@Model.DisplayOrder" />
            </div>
            <div class="col-md-6 mb-3">
                <label for="Icon" class="form-label">Material Icon Name</label>
                <input type="text" class="form-control" id="Icon" name="Icon" value="@Model.Icon" placeholder="e.g. biotech, query_stats" />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label d-block">Featured Banner Image</label>
            @if (!string.IsNullOrEmpty(Model.FeaturedImage))
            {
                <div class="mb-2">
                    <img src="@Model.FeaturedImage" class="img-thumbnail rounded" style="max-height: 120px;" alt="Banner Image" />
                </div>
            }
            <input class="form-control" type="file" id="featuredImageFile" name="featuredImageFile" accept="image/*" />
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-primary-admin px-4">Save Changes</button>
            <a href="/Admin/AcademicPrograms" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
